---
import { Image } from "astro:assets";
import mainBanner from "../assets/pigauto99-cover.webp";
import Bg from "../assets/PIGAUTO-BG.webp";
import "../styles/global.css";
import Navbar from ".././pages/components/Navbar.astro";
const { title } = Astro.props;
---

<html lang="th">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="PIGAUTO99 บริการสล็อตออนไลน์เว็บตรง ไม่ผ่านเอเย่นต์ ฝาก-ถอนไม่มีขั้นต่ำ รองรับวอเลท ระบบออโต้ที่เร็วที่สุดในไทย" />

    <link rel="preload" href="/fonts/kanit-v17-latin_thai-regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/kanit-v17-latin_thai-700.woff2" as="font" type="font/woff2" crossorigin />
    <style is:global>
      body {
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        background-repeat: no-repeat;
        margin: 0;
        background-color: #800000;
        font-weight: 400;
        font-family: "Kanit", sans-serif !important;
        color: white;
      }
    </style>
  </head>

  <body class="h-screen w-full bg-cover bg-center" style={`background-image: url(${Bg.src});`}>
    <Navbar />
    <div class="mb-2.5 flex w-full flex-1 items-center justify-center">
      <Image
        src={mainBanner}
        alt="Pigauto"
        loading="eager"
        fetchpriority="high"
        widths={[412, 768, 1900]}
        sizes="(max-width: 412px) 412px,(max-width: 768px) 768px,1900px"
        class="mx-auto h-auto w-full max-w-[1900px] object-contain drop-shadow-xl"
        decoding="async"
        format="avif"
      />
    </div>
    <slot />
  </body>
</html>
