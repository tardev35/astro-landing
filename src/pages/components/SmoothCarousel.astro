---
import "swiper/css";

import { Image } from "astro:assets";

import banner1 from "../../assets/pro2-2.webp";
import banner2 from "../../assets/pro1-2.webp";
import banner3 from "../../assets/pro4-1.webp";

const images = [banner1, banner2, banner3];
const displayImages = [...images, ...images, ...images];
---

<div class="mx-auto w-full max-w-[1101px] overflow-hidden px-4 py-5">
  <div class="swiper mySwiper">
    <div class="swiper-wrapper">
      {
        displayImages.map((img, index) => (
          <div class="swiper-slide">
            <Image
              src={img}
              alt={`Banner ${index + 1}`}
              class="block aspect-square w-full rounded-xl object-cover shadow-md"
              width={img.width}
              height={img.height}
              loading={index < 2 ? "eager" : "lazy"}
              fetchpriority={index === 0 ? "high" : "auto"}
              decoding="async"
              widths={[200, 400, 600]}
              sizes="(max-width: 768px) 50vw, 33vw"
              format="avif"
            />
          </div>
        ))
      }
    </div>
  </div>
</div>

<script>
  function initSwiper() {
    import("swiper").then(({ default: Swiper }) => {
      import("swiper/modules").then(({ Autoplay }) => {
        new Swiper(".mySwiper", {
          modules: [Autoplay],
          loop: true,
          spaceBetween: 12,
          speed: 8000,
          autoplay: {
            delay: 0,
            disableOnInteraction: false,
          },
          slidesPerView: 2,
          breakpoints: {
            768: {
              slidesPerView: 3,
              spaceBetween: 16,
            },
          },

          init: false,
        }).init();
      });
    });
  }

  window.addEventListener("load", () => {
    setTimeout(() => {
      initSwiper();
    }, 100);
  });

  document.addEventListener("astro:page-load", () => {
    setTimeout(() => {
      initSwiper();
    }, 100);
  });
</script>
<style>
  .swiper-wrapper {
    transition-timing-function: linear !important;
  }
</style>
