---
const { title } = Astro.props;
---

<section class="my-2 flex justify-center">
  <div class="my-1 flex w-full justify-center px-4">
    <div
      class="w-full max-w-7xl rounded-[15px] border-2 border-[#d4af37] bg-[#8B0000]/90 p-8 text-center shadow-2xl"
      style="box-shadow: 0 0 14px rgba(212, 175, 55, 0.65), inset 0 0 12px rgba(212, 175, 55, 0.35)">
      {title && <h2 class="mb-4 text-3xl font-bold">{title}</h2>}

      <div class="text-white">
        <slot />
      </div>
    </div>
  </div>
</section>
